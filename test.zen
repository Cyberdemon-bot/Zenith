// ==========================================
// 1. GLOBAL VARIABLES & ARRAYS
// ==========================================
let MATRIX_SIZE: int = 4;
let MAP: int[4][4] = []; // Bàn cờ / Ma trận đồ thị 4x4

// Các hằng số Bitmask toàn cục
let BITMASK_LOW: int = 255;
let BITMASK_HIGH: int = 65280; // 1111 1111 0000 0000

// Biến đếm số bước chạy toàn cục để test toán tử hậu tố (postfix)
let TOTAL_EXECUTION_STEPS: int = 0;


// ==========================================
// 2. FEATURE TEST: FLOAT & POW (HÌNH HỌC)
// ==========================================
// Hàm tính bình phương khoảng cách giữa 2 điểm (x1, y1) và (x2, y2)
def calculate_distance_sq(x1: float, y1: float, x2: float, y2: float) -> float {
    TOTAL_EXECUTION_STEPS++;
    
    // Ép Parser xử lý độ ưu tiên: (x2 - x1)**2.0 + (y2 - y1)**2.0
    // Lũy thừa (**) bắt buộc phải chạy trước phép cộng (+)
    let dx: float = x2 - x1;
    let dy: float = y2 - y1;
    let dist_sq: float = dx ** 2.0 + dy ** 2.0;
    
    return dist_sq;
}


// ==========================================
// 3. FEATURE TEST: ARRAYS & ELSE-IF (ĐỒ THỊ)
// ==========================================
def init_map() -> int {
    let r: int = 0;
    while r < MATRIX_SIZE {
        let c: int = 0;
        while c < MATRIX_SIZE {
            MAP[r][c] = 0;
            c++;
        }
        r++;
    }
    
    // Đặt chướng ngại vật (-1) và điểm thưởng (10, 20) trên bản đồ
    MAP[0][1] = -1;
    MAP[1][1] = -1;
    MAP[2][2] = 10;
    MAP[3][3] = 20;
    return 0;
}

// Hàm duyệt đồ thị tìm điểm thưởng, test sâu chuỗi IF - ELSE IF - ELSE
def scan_map_score(row: int, col: int) -> int {
    TOTAL_EXECUTION_STEPS++;
    
    let tile_value: int = MAP[row][col];
    
    // Ép Parser và Evaluator test toàn diện cấu trúc Rẽ Nhánh Phức Tạp
    if tile_value == -1 {
        return 0; // Gặp tường, không có điểm
    } else if tile_value == 10 {
        return 100; // Ô đặc biệt loại 1
    } else if tile_value == 20 {
        return 500; // Ô đặc biệt loại 2
    } else {
        // Ô trống bình thường, tính điểm dựa trên tọa độ tuyến tính
        return row * 5 + col; 
    }
}


// ==========================================
// 4. FEATURE TEST: BITWISE & LOGIC SHORT-CIRCUIT
// ==========================================
def generate_crypto_checksum(score1: int, score2: int, geo_factor: int) -> int {
    TOTAL_EXECUTION_STEPS++;
    
    // Kết hợp dữ liệu số nguyên thu được từ các bài toán trước
    let raw_data: int = (score1 << 8) | score2;
    
    // Phép toán bitwise lồng nhau liên tục: BITAND > BITXOR > BITOR
    // Thử thách khả năng xếp tầng AST phẳng của Pratt Parser
    let hash: int = raw_data & BITMASK_HIGH ^ geo_factor | BITMASK_LOW;
    
    // Test logic chập mạch (Short-circuit Evaluation) kết hợp dịch bit và so sánh
    // Nếu (hash & 1) == 0 SAI, Evaluator bắt buộc phải dừng, không được chạy vế sau!
    if (hash & 1) == 0 && (hash >> 4) > 100 {
        hash = hash ^ 5555;
    } else {
        hash = hash ^ 9999;
    }
    
    return hash;
}


// ==========================================
// 5. MAIN ENTRY POINT
// ==========================================
def main() -> int {
    // Kích hoạt hệ thống
    init_map();
    TOTAL_EXECUTION_STEPS++;

    // --- TEST PHẦN 1: FLOAT MATH ---
    // Tính khoảng cách từ gốc (0.0, 0.0) tới (3.0, 4.0). 
    // Kết quả mong đợi: 3.0**2 + 4.0**2 = 9.0 + 16.0 = 25.0
    let distance: float = calculate_distance_sq(0.0, 0.0, 3.0, 4.0);
    
    // Chuyển đổi float thành int một cách toán học (để truyền vào hàm bitwise)
    let geo_int: int = 0;
    if distance > 20.0 {
        geo_int = 25;
    } else {
        geo_int = 10;
    }

    // --- TEST PHẦN 2: IF-ELSE-IF & ARRAYS ---
    let total_score: int = 0;
    
    // Duyệt qua một số ô bằng vòng lặp để tích điểm
    let i: int = 0;
    while i < 4 {
        // Gọi hàm quét bản đồ để kích hoạt các nhánh Else-If khác nhau
        let s1: int = scan_map_score(i, i); // Duyệt đường chéo (0,0), (1,1), (2,2), (3,3)
        total_score = total_score + s1;
        i++;
    }
    // Giá trị s1 qua các vòng lặp:
    // i=0: MAP[0][0] = 0  => Nhánh else => 0 * 5 + 0 = 0
    // i=1: MAP[1][1] = -1 => Nhánh if   => 0
    // i=2: MAP[2][2] = 10 => Nhánh else if 1 => 100
    // i=3: MAP[3][3] = 20 => Nhánh else if 2 => 500
    // => total_score = 0 + 0 + 100 + 500 = 600

    // Quét thêm một ô trống bình thường để lấy giá trị biên lẻ
    let extra_score: int = scan_map_score(2, 3); 
    // MAP[2][3] = 0 => Nhánh else => 2 * 5 + 3 = 13

    // --- TEST PHẦN 3: BITWISE CRYPTO ---
    // total_score = 600, extra_score = 13, geo_int = 25
    let final_result: int = generate_crypto_checksum(total_score, extra_score, geo_int);
    
    // Tăng bước chạy cuối cùng trước khi exit
    TOTAL_EXECUTION_STEPS++;

    return final_result;
}