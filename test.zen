// ================================================================
// ULTIMATE STRESS TEST — Zen Language
// Tests complexity of language constructs, NOT execution speed.
//
// What this covers:
//   - Deep mutual recursion with non-trivial base cases
//   - 3D array manipulation with computed indices
//   - Closures over mutable globals (state machine)
//   - Chained bitwise + logical expressions in conditions
//   - Freestanding blocks for scoped temporaries
//   - All assignment operators inside nested loops
//   - For + while mixed, break/continue with compound conditions
//   - Multi-level index assignment (a[f(i)][g(j)] = expr)
//   - Postfix inside expressions, not just statements
//   - Deeply nested if/else-if chains
//   - Functions calling functions calling functions (4 levels deep)
//   - All infix operators in one expression tree
// ================================================================


// ================================================================
// GLOBALS — shared mutable state accessed from multiple functions
// ================================================================

let CALL_DEPTH_MAX: int   = 0;
let CALL_DEPTH_CURR: int  = 0;
let CHECKSUM: int         = 0;
let CUBE: int[4][4][4]    = [];   // 3-D 4x4x4, all zeros
let VISITED: int[16]      = [];   // flat 16-cell visited log
let VISIT_COUNT: int      = 0;


// ================================================================
// SECTION 1 — MUTUAL RECURSION
// is_even and is_odd call each other; depth tracks max call depth
// ================================================================

def is_even(n: int) -> bool {
    CALL_DEPTH_CURR++;
    if CALL_DEPTH_CURR > CALL_DEPTH_MAX {
        CALL_DEPTH_MAX = CALL_DEPTH_CURR;
    }

    let result: bool = false;
    if n == 0 {
        result = true;
    } else {
        result = is_odd(n - 1);
    }

    CALL_DEPTH_CURR--;
    return result;
}

def is_odd(n: int) -> bool {
    CALL_DEPTH_CURR++;
    if CALL_DEPTH_CURR > CALL_DEPTH_MAX {
        CALL_DEPTH_MAX = CALL_DEPTH_CURR;
    }

    let result: bool = false;
    if n == 0 {
        result = false;
    } else {
        result = is_even(n - 1);
    }

    CALL_DEPTH_CURR--;
    return result;
}


// ================================================================
// SECTION 2 — RECURSIVE ACCUMULATOR WITH FREESTANDING BLOCKS
// Computes a weighted sum: sum(k=1..n) of k * parity_weight(k)
// parity_weight = 3 if even, 1 if odd
// Uses freestanding blocks to scope temporaries at each level
// ================================================================

def weighted_sum(n: int) -> int {
    if n <= 0 {
        return 0;
    }

    let weight: int = 0;
    {
        // Freestanding block: compute weight without polluting outer scope
        let even_check: bool = is_even(n);
        let base: int = 1;
        if even_check {
            base = 3;
        }
        weight = n * base;
    }

    // weight is set, even_check and base are gone
    return weight + weighted_sum(n - 1);
}


// ================================================================
// SECTION 3 — 3D ARRAY: WRITE WITH COMPUTED INDICES
// Fills CUBE[i][j][k] = f(i,j,k) using nested for loops
// Then reads it back through a scan function
// ================================================================

def fill_cube() -> int {
    for let i: int = 0; i < 4; i++ {
        for let j: int = 0; j < 4; j++ {
            for let k: int = 0; k < 4; k++ {
                // Value = bitwise mix of coordinates
                let val: int = (i << 4) | (j << 2) | k;
                CUBE[i][j][k] = val;
            }
        }
    }
    return 0;
}

def read_cube_checksum() -> int {
    let acc: int = 0;
    for let i: int = 0; i < 4; i++ {
        for let j: int = 0; j < 4; j++ {
            for let k: int = 0; k < 4; k++ {
                // XOR-fold everything together
                acc = acc ^ CUBE[i][j][k];
                // Also mutate via computed index assignment
                CUBE[i][j][k] = CUBE[i][j][k] & 255;
            }
        }
    }
    return acc;
}


// ================================================================
// SECTION 4 — STATE MACHINE VIA GLOBALS + COMPLEX CONDITIONS
// Simulates a 4-state machine that transitions based on
// combined bitwise + logical conditions on the current step
// States: 0=IDLE, 1=RUNNING, 2=WAIT, 3=DONE
// ================================================================

let FSM_STATE: int  = 0;
let FSM_STEPS: int  = 0;
let FSM_OUTPUT: int = 0;

def fsm_tick(input: int) -> int {
    FSM_STEPS++;

    // Complex condition using all: &&, ||, &, |, ^, <<, >>
    let is_trigger: bool   = (input & 1) == 1 && (input >> 1) > 0;
    let is_reset: bool     = (input ^ 255) == 0 || (input & 128) != 0;
    let is_advance: bool   = !is_reset && is_trigger;

    if FSM_STATE == 0 {
        if is_advance {
            FSM_STATE = 1;
            FSM_OUTPUT = input << 1;
        }
    } else if FSM_STATE == 1 {
        if is_reset {
            FSM_STATE = 0;
            FSM_OUTPUT = 0;
        } else if is_advance {
            FSM_STATE = 2;
            FSM_OUTPUT = FSM_OUTPUT | (input & 15);
        }
    } else if FSM_STATE == 2 {
        if is_advance {
            FSM_STATE = 3;
            FSM_OUTPUT = FSM_OUTPUT ^ (input >> 2);
        } else {
            FSM_OUTPUT += input;
        }
    } else {
        // State 3: DONE — stay here, fold input into output
        FSM_OUTPUT = (FSM_OUTPUT + input) & 65535;
    }

    return FSM_OUTPUT;
}


// ================================================================
// SECTION 5 — FLAT VISITOR: for loop + break/continue
// Visits cells in VISITED[], logs non-zero CUBE diagonal values,
// uses continue to skip zeros, break when VISIT_COUNT hits 8
// ================================================================

def visit_diagonal() -> int {
    let i: int = 0;
    while i < 16 {
        let row: int = i / 4;
        let col: int = i % 4;
        let val: int = CUBE[row][col][row % 4];

        if val == 0 {
            i++;
            continue;
        }

        VISITED[VISIT_COUNT] = val;
        VISIT_COUNT++;

        if VISIT_COUNT >= 8 {
            break;
        }

        i++;
    }
    return VISIT_COUNT;
}


// ================================================================
// SECTION 6 — DEEP CALL CHAIN: 4 functions each transforming a value
// Each applies a different operator class:
//   L1: arithmetic   (+, -, *, /)
//   L2: bitwise      (&, |, ^, <<, >>)
//   L3: compound assign inside loop
//   L4: recursive with local 2D array scratch space
// ================================================================

def transform_l1(x: int) -> int {
    let a: int = x * 3 + 7;
    let b: int = a - (a / 10);
    return b % 1000;
}

def transform_l2(x: int) -> int {
    let mask: int = 255;
    let hi: int   = (x << 4) & 65280;
    let lo: int   = x & mask;
    return hi | lo ^ (x >> 2);
}

def transform_l3(x: int) -> int {
    let acc: int = x;
    for let i: int = 1; i <= 5; i++ {
        if i % 2 == 0 {
            acc += i;
        } else {
            acc *= i;
            if acc > 100000 {
                acc = acc % 10007;
            }
        }
    }
    return acc;
}

def transform_l4(x: int, depth: int) -> int {
    if depth <= 0 {
        return x;
    }

    // Local 2D scratch — tests nd-array in recursive context
    let scratch: int[3][3] = [[0, 0, 0], [0, 0, 0], [0, 0, 0]];

    {
        let r: int = 0;
        while r < 3 {
            let c: int = 0;
            while c < 3 {
                scratch[r][c] = (x + r * 3 + c) % 17;
                c++;
            }
            r++;
        }
    }

    // Sum the anti-diagonal
    let anti_diag_sum: int = scratch[0][2] + scratch[1][1] + scratch[2][0];

    return transform_l4(anti_diag_sum, depth - 1);
}

def deep_transform(x: int) -> int {
    let v1: int = transform_l1(x);
    let v2: int = transform_l2(v1);
    let v3: int = transform_l3(v2);
    let v4: int = transform_l4(v3, 4);
    return v4;
}


// ================================================================
// SECTION 7 — OPERATOR PRECEDENCE GAUNTLET
// One expression that exercises every precedence level in order.
// Result is checked against manual calculation in main().
// ================================================================

def precedence_gauntlet(a: int, b: int, c: int) -> int {
    // Precedence (low→high): || < && < | < ^ < & < == < < > < << >> < + - < * / % < ** < prefix < call < index
    // Build something that would give a WRONG answer if any level is swapped

    let arr: int[4] = [2, 3, 5, 7];

    // arr[1] = 3, arr[2] = 5
    // Step by step (correct precedence):
    //   arr[1] ** 2       = 9
    //   -arr[2]           = -5
    //   9 * b             = 9 * b
    //   -5 + c            = c - 5
    //   (9*b) + (c-5)    
    //   & 255
    //   ^ a
    //   | 1
    //   result == 0  → false (1 bit set)
    //   false && true → false
    //   false || (a > 0) → depends on a

    let raw: int    = arr[1] ** 2 * b + -arr[2] + c & 255 ^ a | 1;
    let flag: bool  = raw == 0 && b > 0 || a > 0;

    if flag {
        return raw + 1;
    }
    return raw;
}


// ================================================================
// MAIN
// ================================================================

def main() -> int {

    // ---- 1. Mutual recursion + call depth tracking
    let even8: bool = is_even(8);
    let odd7: bool  = is_odd(7);
    // even8=true, odd7=true, CALL_DEPTH_MAX=9 (8 recursive calls + initial)

    // ---- 2. Weighted sum
    let wsum: int = weighted_sum(8);
    // k=1(w=1):1, k=2(w=3):6, k=3(w=1):3, k=4(w=3):12,
    // k=5(w=1):5, k=6(w=3):18, k=7(w=1):7, k=8(w=3):24 → total=76

    // ---- 3. 3D cube fill + checksum
    fill_cube();
    let cube_xor: int = read_cube_checksum();
    // XOR of all (i<<4)|(j<<2)|k for i,j,k in [0,4)

    // ---- 4. FSM: run 10 ticks with varied inputs
    let inputs: int[10] = [3, 7, 128, 5, 255, 11, 2, 9, 64, 15];
    let fsm_last: int   = 0;
    for let t: int = 0; t < 10; t++ {
        fsm_last = fsm_tick(inputs[t]);
    }

    // ---- 5. Visit diagonal (must run after fill_cube)
    visit_diagonal();
    let visit_log_sum: int = 0;
    {
        let vi: int = 0;
        while vi < VISIT_COUNT {
            visit_log_sum += VISITED[vi];
            vi++;
        }
    }

    // ---- 6. Deep 4-level transform
    let transformed: int = deep_transform(42);

    // ---- 7. Precedence gauntlet
    let prec_result: int = precedence_gauntlet(5, 3, 7);

    // ---- 8. All compound assigns in one block (scope-isolated)
    let compound_result: int = 0;
    {
        let v: int = 100;
        v += 50;    // 150
        v -= 25;    // 125
        v *= 2;     // 250
        v /= 5;     // 50
        v %= 13;    // 50 % 13 = 11
        compound_result = v;
    }

    // ---- 9. Nested index assign with postfix in index position
    let grid: int[4][4] = [];
    {
        let ii: int = 0;
        while ii < 4 {
            let jj: int = 0;
            while jj < 4 {
                grid[ii][jj] = ii * 4 + jj;
                jj++;
            }
            ii++;
        }
        // Overwrite diagonal using postfix result as value
        let d: int = 0;
        while d < 4 {
            grid[d][d] = d * d;
            d++;
        }
    }
    let grid_sum: int = 0;
    {
        let gi: int = 0;
        while gi < 4 {
            let gj: int = 0;
            while gj < 4 {
                grid_sum += grid[gi][gj];
                gj++;
            }
            gi++;
        }
    }
    // Off-diagonal: 0*4+1=1, 0*4+2=2, 0*4+3=3,
    //               1*4+0=4,           1*4+2=6, 1*4+3=7,
    //               2*4+0=8, 2*4+1=9,           2*4+3=11,
    //               3*4+0=12,3*4+1=13,3*4+2=14
    // Diagonal: 0,1,4,9
    // Total = (0+1+2+...+15) - (0+5+10+15) + (0+1+4+9)
    //       = 120 - 30 + 14 = 104

    // ---- 10. Final checksum: fold everything together
    CHECKSUM = wsum ^ cube_xor ^ fsm_last ^ visit_log_sum ^ transformed ^ prec_result ^ compound_result ^ grid_sum;

    if even8 && odd7 {
        CHECKSUM = CHECKSUM | 1;
    }

    return CHECKSUM;
}
