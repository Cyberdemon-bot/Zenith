// ================================================================
// ZEN LANGUAGE — NULLABLE STATE TEST SUITE
// Tests memory safety rules, postfix '!' (returns bool), and mut params.
// ================================================================

// Mảng không thể Null, chỉ có phần tử mới được phép Null
// Khi vừa khai báo trống, toàn bộ 4 ô nhớ nhận trạng thái Null ẩn của hệ thống
let mut INVENTORY: int?[4] = []; 


// Hàm xử lý vật phẩm: Nhận vào một tham số có thể Null và có thể chỉnh sửa
def update_item_slot(slot: int, mut incoming_power: int?) -> int {
    
    // 1. Dùng toán tử Postfix ! để check trạng thái tồn tại của dữ liệu
    // Nếu incoming_power ĐANG CÓ giá trị, '!' trả về true. Ngược lại trả về false.
    let mut is_valid: bool = incoming_power!;
    
    if is_valid {
        // Tự động tính toán (Nếu có giá trị thì tính bình thường)
        incoming_power = incoming_power * 2; 
    } else {
        // Nếu ban đầu truyền vào trống (Null), ta gán giá trị mặc định cho nó
        // Từ khoảnh khắc này, biến thoát kiếp Null vĩnh viễn, không thể quay lại Null!
        incoming_power = 100;
    }
    
    // Cập nhật vào mảng toàn cục
    INVENTORY[slot] = incoming_power;
    
    return INVENTORY[slot];
}

def main() -> int {
    let mut score_log: int = 0;

    // ---- TEST CASE 1: Biến Nullable chưa khởi tạo ----
    let mut initial_power: int?; // Tự động mang trạng thái Null ẩn do chưa gán gì
    
    // Check thử bằng toán tử Postfix ! bên ngoài hàm
    let mut check_null: bool = initial_power!; // Sẽ nhận giá trị 'false' vì đang Null
    
    // Gọi hàm truyền initial_power (đang Null) vào slot 0
    // Hàm thấy false -> tự kích hoạt fallback gán bằng 100 -> Lưu vào mảng
    let mut res1: int = update_item_slot(0, initial_power);
    score_log += res1; // score_log = 100


    // ---- TEST CASE 2: Gán giá trị để biến thoát kiếp Null ----
    initial_power = 42; // Bây giờ initial_power mang giá trị thực, hết Null!
    
    let mut check_again: bool = initial_power!; // Sẽ nhận giá trị 'true' vì đã có giá trị
    
    if check_again {
        // Gọi hàm truyền initial_power (lúc này đã là 42) vào slot 1
        // Hàm thấy true -> lọt vào block nhân đôi -> 42 * 2 = 84 -> Lưu vào mảng
        let mut res2: int = update_item_slot(1, initial_power);
        score_log += res2; // score_log = 100 + 84 = 184
    }

    return score_log; // Kết quả mong đợi cuối cùng: 184
}